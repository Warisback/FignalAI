# Copy this to .env and fill in your keys
# Never commit .env to git

# ---- Cerebras ----
# Your Cerebras API key (from cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_key_here

# Model. gemma-4-31b is the target (multimodal, full tier). Fallbacks that also
# work: gpt-oss-120b (text only). NOTE: gemma uses reasoning_effort=none;
# gpt-oss-120b needs low|medium|high (it rejects none).
CEREBRAS_MODEL=gemma-4-31b
CEREBRAS_EFFORT=none

# Rate limits — match your tier. Full tier is 100 RPM / 100K TPM. The free tier
# is ~5 RPM / 30K TPM; the loop paces itself to that automatically.
CEREBRAS_RPM=100
CEREBRAS_MAX_CONCURRENCY=8

# ---- Pipeline shape ----
CODE_K=5                       # 5-way self-consistency fan-out
CODE_TEMPERATURE=0.5
ENABLE_VERIFIER=true           # advisory — the simulator is the oracle

# Vision input mode: "text" | "image" | "hybrid".
#   hybrid = waveform PNG + exact per-cycle table (multimodal AND precise).
VISION_MODE=hybrid

# ---- GPU baseline (side-by-side speed comparison) ----
# Assumed GPU throughput (tokens/sec) for the PROJECTED baseline when no live
# baseline host is configured. ~50-80 tok/s is realistic for a ~100B model.
BASELINE_TPS=60

# Optional: a real OpenAI-compatible host running the SAME model, for a live
# side-by-side instead of a projection (Together AI / OpenRouter host gpt-oss).
BASELINE_BASE_URL=https://api.openai.com/v1
BASELINE_API_KEY=your_baseline_key_here
BASELINE_MODEL=gpt-4o-mini
