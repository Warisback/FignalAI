# Copy this to .env and fill in your keys
# Never commit .env to git

# ---- Cerebras ----
# Your Cerebras API key (from cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_key_here

# Model to use. Default gpt-oss-120b (text agents work today).
# Swap to gemma-4-31b once your access (incl. multimodal) lands.
CEREBRAS_MODEL=gpt-oss-120b

# Reasoning effort: gpt-oss-120b accepts low|medium|high (NOT none);
# gemma-4-31b also accepts "none".
CEREBRAS_EFFORT=low

# Rate limits — match your tier. The free tier is ~5 RPM / 30K TPM, so the
# loop paces itself to avoid 429s. When your hackathon tier (100 RPM) lands,
# raise these and the 5-way fan-out runs truly in parallel.
CEREBRAS_RPM=5
CEREBRAS_MAX_CONCURRENCY=5

# ---- Pipeline shape ----
# vision(1) + code(CODE_K) + patch(1) = 5 calls fits one 5-RPM window.
CODE_K=3
CODE_TEMPERATURE=0.5
ENABLE_VERIFIER=false          # turn on once you have RPM headroom

# Vision input mode: "text" (works on any model) or "image" (needs multimodal).
VISION_MODE=text

# ---- GPU baseline (side-by-side speed comparison) ----
# Assumed GPU throughput (tokens/sec) for the PROJECTED baseline when no live
# baseline host is configured. ~50-80 tok/s is realistic for a ~100B model.
BASELINE_TPS=60

# Optional: a real OpenAI-compatible host running the SAME model, for a live
# side-by-side instead of a projection (Together AI / OpenRouter host gpt-oss).
BASELINE_BASE_URL=https://api.openai.com/v1
BASELINE_API_KEY=your_baseline_key_here
BASELINE_MODEL=gpt-4o-mini
